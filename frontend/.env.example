# Google AI Studio / Gemini — yalnızca sunucu tarafında kullanılır (asla istemciye gömülmez)
GEMINI_API_KEY=
# Boş bırakılırsa önce gemini-2.5-flash denenir; 404 olursa sunucu sırayla diğer model adlarını dener.
# Kendi hesabında gördüğün tam model adını da yazabilirsin (AI Studio → model listesi).
GEMINI_MODEL=gemini-2.5-flash

# Opsiyonel — FastAPI backend kök adresi. Boş bırakılırsa otomatik:
#   Yerel tarayıcı: /api (next.config proxy → localhost:8000)
#   Vercel canlı: /_backend (vercel.json monorepo backend)
#   Sunucu (SSR): https://<VERCEL_URL>/_/backend
# NEXT_PUBLIC_API_URL=/_backend
