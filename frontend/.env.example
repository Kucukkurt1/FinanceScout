# Google AI Studio / Gemini — yalnızca sunucu tarafında kullanılır (asla istemciye gömülmez)
GEMINI_API_KEY=
# Boş bırakılırsa önce gemini-2.5-flash denenir; 404 olursa sunucu sırayla diğer model adlarını dener.
# Kendi hesabında gördüğün tam model adını da yazabilirsin (AI Studio → model listesi).
GEMINI_MODEL=gemini-2.5-flash
